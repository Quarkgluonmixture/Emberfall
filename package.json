{
  "name": "emberfall",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An idle civilization ecosystem simulation — a living world in a bottle.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "art:shots": "node scripts/art-audit-shots.mjs",
    "art:audit": "node scripts/art-audit.mjs",
    "art:review": "node scripts/art-review.mjs"
  },
  "dependencies": {
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.4",
    "sharp": "^0.33.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
